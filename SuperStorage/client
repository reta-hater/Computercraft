local currentVariants = nil
local currentVariantItem = nil

local function hideVariantButtons()
    for _, btn in ipairs(variantButtons) do
        btn:setVisible(false)
    end
end

local function selectVariant(index)
    if not currentVariants or not currentVariants[index] then return end
    local countText = requestCountInput:getText()
    if countText == "" then
        setMessage("Enter a count or 'all' first.", colors.red)
        return
    end
    local count = (countText:lower() == "all") and "all" or tonumber(countText)
    if count == nil then
        setMessage("Invalid count.", colors.red)
        return
    end
    local chosen = currentVariants[index]

    setMessage("Requesting variant...", colors.yellow)
    local resp = send({
        cmd = "request",
        item = currentVariantItem,
        count = count,
        nbt = chosen.nbt,
    })
    if not resp then
        setConnected(false)
        setMessage("No response from server.", colors.red)
    elseif resp.ok then
        setConnected(true)
        setMessage(resp.msg, colors.lime)
        hideVariantButtons()
        requestItemInput:setText("")
        requestCountInput:setText("")
    else
        setConnected(true)
        setMessage(resp.err, colors.red)
    end
end

local function doRequest()
    local itemText = requestItemInput:getText()
    local countText = requestCountInput:getText()

    if itemText == "" then
        setMessage("Enter an item name.", colors.red)
        return
    end
    if countText == "" then
        setMessage("Enter a count or 'all'.", colors.red)
        return
    end

    local count = (countText:lower() == "all") and "all" or tonumber(countText)
    if count == nil then
        setMessage("Invalid count.", colors.red)
        return
    end

    if itemText:find(",") then
        setMessage("Requesting multiple items...", colors.yellow)
        local resp = send({ cmd = "request_multi", items = itemText, count = count })
        if not resp then
            setConnected(false)
            setMessage("No response from server.", colors.red)
        elseif resp.ok then
            setConnected(true)
            setMessage(resp.msg or "Done.", colors.lime)
            requestItemInput:setText("")
            requestCountInput:setText("")
        else
            setConnected(true)
            setMessage(resp.err or "Failed.", colors.red)
        end
        return
    end

    setMessage("Checking item...", colors.yellow)
    local varResp = send({ cmd = "variants", item = itemText })

    if varResp and varResp.ok and varResp.variants and #varResp.variants > 1 then
        currentVariants = varResp.variants
        currentVariantItem = itemText
        hideVariantButtons()
        for i, v in ipairs(currentVariants) do
            if i <= MAX_VARIANT_ROWS then
                local label = (v.enchants or "Plain") .. "  x" .. v.count
                if #label > 30 then label = label:sub(1, 29) .. "~" end
                variantButtons[i]:setText(label)
                variantButtons[i]:setVisible(true)
            end
        end
        setMessage("Multiple variants - tap one below:", colors.yellow)
        return
    end

    hideVariantButtons()
    local resp = send({ cmd = "request", item = itemText, count = count })
    if not resp then
        setConnected(false)
        setMessage("No response from server.", colors.red)
    elseif resp.ok then
        setConnected(true)
        setMessage(resp.msg, colors.lime)
        requestItemInput:setText("")
        requestCountInput:setText("")
    else
        setConnected(true)
        setMessage(resp.err, colors.red)
    end
end

for i, btn in ipairs(variantButtons) do
    btn:onClick(function()
        if not currentVariants or not currentVariants[i] then return end
        local chosen = currentVariants[i]
        local itemName = currentVariantItem
        local key = itemName .. "|" .. tostring(chosen.nbt or "")
        handleTap(
            "variant_row_" .. i,
            key,
            function() selectVariant(i) end,
            function()
                local label = chosen.enchants or itemName
                showDetailPopup(itemName, chosen.nbt, label)
            end
        )
    end)
end

