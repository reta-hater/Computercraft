local allStock = {}
local filteredStock = {}
local stockPage = 1
local stockRowLabels = {}
local STOCK_ROWS_PER_PAGE = 10
local sortMode = "name" -- "name", "count_desc", "count_asc"

local function applySortToStock(items)
    local sorted = {}
    for _, v in ipairs(items) do table.insert(sorted, v) end
    if sortMode == "count_desc" then
        table.sort(sorted, function(a, b) return a.count > b.count end)
    elseif sortMode == "count_asc" then
        table.sort(sorted, function(a, b) return a.count < b.count end)
    end
    return sorted
end

for i = 1, STOCK_ROWS_PER_PAGE do
    local rowFrame = stockFrame:addFrame({
        x = 1, y = i,
        width = "{parent.width}",
        height = 1,
        background = colors.black,
    })

    local nameLabel = rowFrame:addLabel({
