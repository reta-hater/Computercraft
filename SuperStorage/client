    if not requestAmount or requestAmount <= 0 then return end
    closeDetailPopup()
    setMessage("Requesting " .. requestAmount .. "x " .. itemName .. "...", colors.yellow)
    local resp = send({ cmd = "request", item = itemName, count = requestAmount, nbt = nbt })
    if not resp then
        setConnected(false)
