local function doDeposit()
    local itemText = depositItemInput:getText()
    local countText = depositCountInput:getText()
    countText = (countText == "" and "all") or countText

    setMessage("Depositing...", colors.yellow)

    local resp
    if itemText == "" or itemText:lower() == "hand" then
        local count
        if countText:lower() == "all" then
            count = 0
        elseif countText:lower() == "alloftype" then
            count = "alloftype"
        else
            count = tonumber(countText)
        end
        if count == nil then
            setMessage("Invalid count.", colors.red)
            return
        end
        resp = send({ cmd = "deposit_hand", count = count })
    else
        local count = (countText:lower() == "all") and 0 or tonumber(countText)
        if count == nil then
            setMessage("Invalid count.", colors.red)
            return
        end
        resp = send({ cmd = "deposit", item = itemText, count = count })
    end

    if not resp then
        setConnected(false)
        setMessage("No response from server.", colors.red)
    elseif resp.ok then
        setConnected(true)
        setMessage(resp.msg, colors.lime)
        depositItemInput:setText("")
        depositCountInput:setText("")
    else
        setConnected(true)
        setMessage(resp.err, colors.red)
    end
end

