local MODEM_SIDE = "back"         -- built-in modem on pocket computers
local PLAYER_NAME = "Steve"       -- !! Change to your in-game name !!
local SERVER_HOSTNAME = "storage_server"
local TIMEOUT = 5                 -- seconds to wait for server response
local DOUBLE_TAP_WINDOW = 0.8     -- seconds allowed between taps to count as a double-tap

rednet.open(MODEM_SIDE)

local serverId = nil

local function findServer()
    local id = rednet.lookup("storage", SERVER_HOSTNAME)
    return id
end

local function send(msg)
    if not serverId then
        serverId = findServer()
        if not serverId then return nil end
    end
    msg.player = PLAYER_NAME
    rednet.send(serverId, msg, "storage")
    local _, response = rednet.receive("storage", TIMEOUT)
    if not response then
        serverId = findServer()
        if not serverId then return nil end
        rednet.send(serverId, msg, "storage")
        _, response = rednet.receive("storage", TIMEOUT)
    end
    return response
end

