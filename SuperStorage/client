        foreground = colors.cyan,
        background = colors.black,
    })
    stockRowLabels[i] = { name = nameLabel, count = countLabel, item = nil }

    rowFrame:onClick(function()
        local row = stockRowLabels[i]
        if not row.item then return end
        local key = row.item.name .. "|" .. tostring(row.item.nbt or "")
        local item = row.item
        handleTap(
            "stock_row_" .. i,
            key,
            function() end, -- single tap on a stock row does nothing
            function()
                local shortName = item.displayName or (item.name:match(":(.+)$") or item.name)
                showDetailPopup(item.name, item.nbt, shortName)
            end
        )
    end)
end

local function renderStockPage()
    local totalPages = math.max(1, math.ceil(#filteredStock / STOCK_ROWS_PER_PAGE))
    if stockPage > totalPages then stockPage = totalPages end
    if stockPage < 1 then stockPage = 1 end

    local startIdx = (stockPage - 1) * STOCK_ROWS_PER_PAGE + 1

    for i = 1, STOCK_ROWS_PER_PAGE do
        local item = filteredStock[startIdx + i - 1]
        local row = stockRowLabels[i]
        row.item = item
        if item then
            local shortName = item.displayName or (item.name:match(":(.+)$") or item.name)
            row.name:setText(shortName)
            row.count:setText("x" .. item.count)
        else
            row.name:setText("")
            row.count:setText("")
        end
    end

    if #filteredStock == 0 then
        stockRowLabels[1].name:setText("(no items found)")
        stockRowLabels[1].count:setText("")
        pageLabel:setText("")
    else
        pageLabel:setText("Page " .. stockPage .. "/" .. totalPages .. "  (" .. #filteredStock .. " items)")
    end
end

local function renderStock(filterText)
    filterText = (filterText or ""):lower()
    local matched = {}
    for _, item in ipairs(allStock) do
        local shortName = item.displayName or (item.name:match(":(.+)$") or item.name)
        if filterText == "" or shortName:lower():find(filterText, 1, true) or item.name:lower():find(filterText, 1, true) then
            table.insert(matched, item)
        end
    end
    filteredStock = applySortToStock(matched)
    stockPage = 1
    renderStockPage()
end

local function refreshStock()
    setMessage("Loading stock...", colors.yellow)
    local resp = send({ cmd = "stock" })
    if not resp then
        setConnected(false)
        setMessage("No response from server.", colors.red)
        return
    end
    setConnected(true)
    if not resp.ok then
        setMessage(resp.err or "Unknown error.", colors.red)
        return
    end
    allStock = resp.stock or {}
    renderStock(stockSearch:getText())
    setMessage("Stock loaded (" .. #allStock .. " items).", colors.lime)
end

stockSearch:onChange("text", function(self, value)
    renderStock(value)
end)

