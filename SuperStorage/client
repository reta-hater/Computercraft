local function startupRoutine()
    sleep(0.5) -- let Basalt's first render pass complete

    local connId = findServer()
    if connId then
        serverId = connId
        setConnected(true)
        setMessage("Connected to server.", colors.lime)
        refreshStock()
    else
        setConnected(false)
        setMessage("Server not found. Use Stock > Refresh to retry.", colors.red)
    end

    while true do
        if #actionQueue > 0 then
            local fn = table.remove(actionQueue, 1)
            local ok, err = pcall(fn)
            if not ok then
                setMessage("Error: " .. tostring(err), colors.red)
            end
        else
            sleep(0.1)
        end
    end
end

parallel.waitForAny(
    function() basalt.run() end,
    startupRoutine
)
