    end
end)

local pendingTap = {} -- rowId -> { key, timerId, singleAction }
local actionQueue = {}

local function queueAction(fn)
    table.insert(actionQueue, fn)
end

local function handleTap(rowId, key, singleAction, doubleAction)
    local pending = pendingTap[rowId]
    if pending and pending.key == key then
        pendingTap[rowId] = nil
        queueAction(doubleAction)
    else
        local timerId = os.startTimer(DOUBLE_TAP_WINDOW)
        pendingTap[rowId] = {
            key = key,
            timerId = timerId,
            singleAction = singleAction,
        }
    end
end

basalt.onEvent("timer", function(id)
    for rowId, pending in pairs(pendingTap) do
        if pending.timerId == id then
            pendingTap[rowId] = nil
            queueAction(pending.singleAction)
            return
        end
    end
end)

