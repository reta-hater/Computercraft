local function wrapText(text, maxWidth)
    local lines = {}
    local current = ""
    for word in text:gmatch("%S+") do
        local candidate = (current == "") and word or (current .. " " .. word)
        if #candidate > maxWidth then
            if current ~= "" then
                table.insert(lines, current)
            end
            if #word > maxWidth then
                local remaining = word
                while #remaining > maxWidth do
                    table.insert(lines, remaining:sub(1, maxWidth))
                    remaining = remaining:sub(maxWidth + 1)
                end
                current = remaining
            else
                current = word
            end
        else
            current = candidate
        end
    end
    if current ~= "" then
        table.insert(lines, current)
    end
    return lines
end

local function showDetailPopup(itemName, nbt, displayNameFallback)
    currentDetailItem = { name = itemName, nbt = nbt }
    detailTitle:setText(displayNameFallback or itemName)
    for i = 1, DETAIL_BODY_LINES do
        detailBodyLabels[i]:setText("")
    end
    detailBodyLabels[1]:setText("Loading...")
    detailQuickRequestBtn:setText("Request 1 Stack")
    detailPopup:setVisible(true)

    local resp = send({ cmd = "item_detail", item = itemName, nbt = nbt })

    if not currentDetailItem or currentDetailItem.name ~= itemName or currentDetailItem.nbt ~= nbt then
        return
    end

    for i = 1, DETAIL_BODY_LINES do
        detailBodyLabels[i]:setText("")
    end

    if not resp or not resp.ok then
        detailBodyLabels[1]:setText(resp and resp.err or "Could not load details.")
        return
    end

    local d = resp.detail
    local line = 1
    local maxWidth = 24 -- conservative width for pocket computer screens

    local function addWrapped(prefix, content)
        local fullText = prefix .. content
        local wrapped = wrapText(fullText, maxWidth)
        for _, wline in ipairs(wrapped) do
            if line <= DETAIL_BODY_LINES then
                detailBodyLabels[line]:setText(wline)
                line = line + 1
            end
        end
    end

    detailTitle:setText(d.displayName or itemName)

    if d.enchants then
        addWrapped("Enchants: ", d.enchants)
    end

    if d.potionEffects then
        addWrapped("Effects: ", d.potionEffects)
    end

    if d.damage ~= nil and d.maxDamage ~= nil then
        local remaining = d.maxDamage - d.damage
        addWrapped("Durability: ", remaining .. "/" .. d.maxDamage)
    end

    if line == 1 then
        detailBodyLabels[1]:setText("No special properties.")
    end

    local maxCount = d.maxCount or 64
    local totalInStorage = d.totalInStorage or 0
    local requestAmount = math.min(maxCount, totalInStorage)
    currentDetailItem.requestAmount = requestAmount

    if requestAmount <= 0 then
        detailQuickRequestBtn:setText("None in storage")
    elseif totalInStorage < maxCount then
        detailQuickRequestBtn:setText("Request All (" .. requestAmount .. ")")
    else
        detailQuickRequestBtn:setText("Request 1 Stack (" .. requestAmount .. ")")
    end
end

detailQuickRequestBtn:onClick(function()
    if not currentDetailItem then return end
    local itemName, nbt = currentDetailItem.name, currentDetailItem.nbt
