local function getBarrelFreeSpace(barrel)
    local ok, items = pcall(barrel.p.list)
    local ok2, size = pcall(barrel.p.size)
    if not ok2 or not size then return 0 end
    if not ok or not items then return 0 end

    local usedSlots = 0
    for _ in pairs(items) do
        usedSlots = usedSlots + 1
    end
    local emptySlots = size - usedSlots
    return emptySlots * 64
end

local function pickNewActiveBarrel(excludeName)
    local best = nil
    local bestSpace = -1
    for _, b in ipairs(barrels) do
        if not b.readOnly and b.name ~= excludeName then
            local space = getBarrelFreeSpace(b)
            if space > bestSpace then
                bestSpace = space
                best = b.name
            end
        end
    end
    return best
end

