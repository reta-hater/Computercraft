local function saveActiveBarrel(name)
    local file = fs.open(ACTIVE_BARREL_FILE, "w")
    if file then
        file.write(name or "")
        file.close()
    end
end

local function loadActiveBarrel()
    if fs.exists(ACTIVE_BARREL_FILE) then
        local file = fs.open(ACTIVE_BARREL_FILE, "r")
        local saved = file.readAll()
        file.close()
        if saved and saved ~= "" then
            for _, b in ipairs(barrels) do
                if b.name == saved and not b.readOnly then
                    return saved
                end
            end
        end
    end
    return nil
end

