local function rebuildBarrelList()
    local newBarrels = {}
    for _, name in ipairs(peripheral.getNames()) do
        local types = { peripheral.getType(name) }
        local hasInventory = false
        local isManager = false
        local isReadOnly = false
        local isExcluded = false
        for _, t in ipairs(types) do
            if t == "inventory" then hasInventory = true end
            if t == "inventory_manager" then isManager = true end
            if READONLY_TYPES[t] then isReadOnly = true end
            if EXCLUDED_TYPES[t] then isExcluded = true end
        end
        if hasInventory and not isManager and not bufferBarrelNames[name] and not isExcluded then
            table.insert(newBarrels, { name = name, p = peripheral.wrap(name), readOnly = isReadOnly })
        end
    end
    barrels = newBarrels
end

